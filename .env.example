# Txtovideo Studio 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# =============================================================================
# 应用基础配置
# =============================================================================
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# =============================================================================
# CORS和安全配置
# =============================================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8080"]
ALLOWED_HOSTS=["*"]

# =============================================================================
# 数据库配置
# =============================================================================
DATABASE_URL=postgresql+asyncpg://txtovideo_user:txtovideo_password@localhost:5432/txtovideo_studio
DATABASE_POOL_PRE_PING=true
DATABASE_POOL_RECYCLE=3600

# =============================================================================
# Redis和Celery配置
# =============================================================================
REDIS_URL=redis://:redis_password@localhost:6379/0
CELERY_BROKER_URL=redis://:redis_password@localhost:6379/0
CELERY_RESULT_BACKEND=redis://:redis_password@localhost:6379/0

# =============================================================================
# JWT配置
# =============================================================================
JWT_SECRET_KEY=dev-only-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =============================================================================
# 加密配置
# =============================================================================
API_KEY_ENCRYPTION_KEY=E2zTzjYpK0cGf3Sq0Y1BVxYI7HzlUv8P4Q6cTg19J0A=

# =============================================================================
# MinIO对象存储配置
# =============================================================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_SECURE=false
MINIO_BUCKET_NAME=txtovideo-files
MINIO_REGION=us-east-1

# =============================================================================
# 头像上传配置
# =============================================================================
AVATAR_BUCKET_NAME=txtovideo-avatars
MAX_AVATAR_SIZE=5242880
ALLOWED_AVATAR_TYPES=["jpg","jpeg","png","webp"]

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=INFO
STRUCTURED_LOGGING=true
LOG_FILE=
COLORED_LOGS=true
