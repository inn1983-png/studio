{
  "name": "txtovideo-studio",
  "version": "1.0.0",
  "description": "Txtovideo Studio - 小说短剧工作站",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:wsl": "npx vitest run --config vitest.direct.config.js",
    "test:basic": "npx vitest run --config vitest.direct.config.js",
    "test:vue": "npx vitest run --config vitest.minimal.config.js",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write .",
    "electron:dev": "node electron/dev.cjs",
    "electron:build": "vite build && node scripts/electron-copy.js && electron-builder --win",
    "electron:build:mac": "vite build && node scripts/electron-copy.js && electron-builder --mac",
    "electron:build:linux": "vite build && node scripts/electron-copy.js && electron-builder --linux"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "electron-updater": "^6.8.3",
    "element-plus": "^2.4.0",
    "konva": "^9.3.20",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-konva": "^3.2.6",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/test-utils": "^2.4.6",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^27.1.0",
    "prettier": "^3.2.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.8",
    "vue-eslint-parser": "^10.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "build": {
    "appId": "com.txtovideo.studio",
    "productName": "Txtovideo Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "installerHeaderIcon": "public/icon.ico"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/icon.icns"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "public/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "txtovideo",
      "repo": "studio"
    }
  }
}
